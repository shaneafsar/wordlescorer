---
import DistributionChart from './DistributionChart.astro';

const db = Astro.locals.runtime.env.DB;

interface RecordData {
  wordleNumber: number;
  failRate: number;
  total: number;
  counts: number[];
}

const cache = await caches.open('wordle-difficulty');
const cacheKey = 'https://cache.local/wordle-difficulty-v3';
const cacheReq = new Request(cacheKey);
let hardest: RecordData | null = null;
let easiest: RecordData | null = null;

const cached = await cache.match(cacheReq);
if (cached) {
  const data = await cached.json();
  hardest = data.hardest;
  easiest = data.easiest;
} else {
  const result = await db
    .prepare(
      `SELECT wordle_number,
              date_key,
              COUNT(*) as total,
              SUM(CASE WHEN solved_row = 0 THEN 1 ELSE 0 END) as unsolved
       FROM global_scores
       GROUP BY wordle_number, date_key
       HAVING total >= 1000`
    )
    .all();

  let maxRate = -1;
  let minRate = 2;
  let hardestNumber = 0;
  let hardestDateKey = '';
  let easiestNumber = 0;
  let easiestDateKey = '';

  for (const r of result.results as any[]) {
    const rate = r.unsolved / r.total;
    if (rate > maxRate) {
      maxRate = rate;
      hardestNumber = r.wordle_number;
      hardestDateKey = r.date_key;
      hardest = { wordleNumber: r.wordle_number, failRate: rate, total: r.total, counts: [] };
    }
    if (rate < minRate) {
      minRate = rate;
      easiestNumber = r.wordle_number;
      easiestDateKey = r.date_key;
      easiest = { wordleNumber: r.wordle_number, failRate: rate, total: r.total, counts: [] };
    }
  }

  // Fetch distributions for hardest and easiest
  if (hardest && easiest) {
    const distQuery = `SELECT solved_row, COUNT(*) as cnt
                       FROM global_scores
                       WHERE wordle_number = ? AND date_key = ?
                       GROUP BY solved_row`;

    const [hardestDist, easiestDist] = await Promise.all([
      db.prepare(distQuery).bind(hardestNumber, hardestDateKey).all(),
      db.prepare(distQuery).bind(easiestNumber, easiestDateKey).all(),
    ]);

    function buildCounts(rows: any[]): number[] {
      const counts = [0, 0, 0, 0, 0, 0, 0]; // index 0=unsolved, 1-6=solved row
      for (const r of rows) {
        counts[r.solved_row] = r.cnt;
      }
      return counts;
    }

    hardest.counts = buildCounts(hardestDist.results as any[]);
    easiest.counts = buildCounts(easiestDist.results as any[]);

    const res = new Response(JSON.stringify({ hardest, easiest }), {
      headers: { 'Cache-Control': 'max-age=21600' },
    });
    await cache.put(cacheReq, res);
  }
}

function pct(rate: number): string {
  return (rate * 100).toFixed(1) + '%';
}

function formatNum(n: number): string {
  return n.toLocaleString();
}
---

{hardest && easiest && (
  <div>
    <h2 class="text-xl font-bold text-text-primary mb-4">Wordle Records</h2>
    <div class="grid grid-cols-2 gap-3">
      <div class="border border-bg-tertiary rounded-lg bg-bg-secondary p-4">
        <p class="text-xs text-text-secondary uppercase tracking-wide mb-1">Hardest Wordle</p>
        <p class="text-2xl font-bold text-accent-red">#{hardest.wordleNumber}</p>
        <p class="text-sm text-text-secondary mt-1">
          <span class="text-accent-red font-semibold">{pct(hardest.failRate)}</span> fail rate
        </p>
        <p class="text-xs text-text-secondary mt-0.5 mb-3">{formatNum(hardest.total)} players</p>
        <DistributionChart counts={hardest.counts} total={hardest.total} compact />
      </div>
      <div class="border border-bg-tertiary rounded-lg bg-bg-secondary p-4">
        <p class="text-xs text-text-secondary uppercase tracking-wide mb-1">Easiest Wordle</p>
        <p class="text-2xl font-bold text-accent-green">#{easiest.wordleNumber}</p>
        <p class="text-sm text-text-secondary mt-1">
          <span class="text-accent-green font-semibold">{pct(easiest.failRate)}</span> fail rate
        </p>
        <p class="text-xs text-text-secondary mt-0.5 mb-3">{formatNum(easiest.total)} players</p>
        <DistributionChart counts={easiest.counts} total={easiest.total} compact />
      </div>
    </div>
  </div>
)}
