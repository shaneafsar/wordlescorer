---
interface Props {
  siteKey: string;
}

const { siteKey } = Astro.props;
const db = Astro.locals.runtime.env.DB;
const pageSize = 20;

const countResult = await db
  .prepare('SELECT COUNT(*) as total FROM analyzed_posts')
  .first<{ total: number }>();
const total = countResult?.total || 0;
const totalPages = Math.ceil(total / pageSize);

const results = await db
  .prepare(
    `SELECT id, scorer_name, wordle_number, score, solved_row, is_hard_mode, source, url, auto_score, created_at
     FROM analyzed_posts ORDER BY created_at DESC LIMIT ?`
  )
  .bind(pageSize)
  .all();

const hits = results.results.map((r: any) => ({
  scorerName: r.scorer_name as string,
  wordleNumber: r.wordle_number as number,
  score: r.score as number,
  solvedRow: r.solved_row as number,
  autoScore: !!r.auto_score,
  url: r.url as string | null,
  dateTimestamp: Math.floor(r.created_at / 1000),
}));

function formatDate(ts: number): string {
  return new Date(ts * 1000).toLocaleDateString('en-US');
}
---

<div>
  <div id="searchbox" class="mb-6">
    <h2 class="text-xl font-bold text-text-primary mb-4">Search Scores</h2>
    <form id="search-form" class="grid grid-cols-1 sm:grid-cols-[1fr_auto_auto_auto_auto_auto] gap-2 items-center">
      <input
        type="text"
        name="q"
        placeholder="Search by username..."
        class="bg-bg-secondary border border-bg-tertiary text-text-primary rounded-lg px-4 py-2.5 text-sm placeholder:text-text-secondary focus:border-accent-blue focus:ring-1 focus:ring-accent-blue"
      />
      <input
        type="number"
        name="wordleNumber"
        placeholder="Wordle #"
        min="1"
        class="bg-bg-secondary border border-bg-tertiary text-text-primary rounded-lg px-3 py-2.5 text-sm placeholder:text-text-secondary focus:border-accent-blue focus:ring-1 focus:ring-accent-blue"
      />
      <select
        name="solvedRow"
        class="bg-bg-secondary border border-bg-tertiary text-text-primary rounded-lg px-3 py-2.5 text-sm focus:border-accent-blue focus:ring-1 focus:ring-accent-blue cursor-pointer"
      >
        <option value="">Any row</option>
        <option value="1">Row 1</option>
        <option value="2">Row 2</option>
        <option value="3">Row 3</option>
        <option value="4">Row 4</option>
        <option value="5">Row 5</option>
        <option value="6">Row 6</option>
        <option value="0">Not solved</option>
      </select>
      <div class="grid grid-cols-2 sm:contents gap-2">
        <input
          type="number"
          name="scoreMin"
          placeholder="Min score"
          min="0"
          class="bg-bg-secondary border border-bg-tertiary text-text-primary rounded-lg px-3 py-2.5 text-sm placeholder:text-text-secondary focus:border-accent-blue focus:ring-1 focus:ring-accent-blue"
        />
        <input
          type="number"
          name="scoreMax"
          placeholder="Max score"
          min="0"
          class="bg-bg-secondary border border-bg-tertiary text-text-primary rounded-lg px-3 py-2.5 text-sm placeholder:text-text-secondary focus:border-accent-blue focus:ring-1 focus:ring-accent-blue"
        />
      </div>
      <select
        name="autoScore"
        class="bg-bg-secondary border border-bg-tertiary text-text-primary rounded-lg px-3 py-2.5 text-sm focus:border-accent-blue focus:ring-1 focus:ring-accent-blue cursor-pointer"
      >
        <option value="">All posts</option>
        <option value="0">@ Mentioned bot</option>
        <option value="1">Auto-scored</option>
      </select>
      <div class="cf-turnstile" data-sitekey={siteKey} data-appearance="interaction-only"></div>
      <div class="flex items-center gap-2">
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 bg-accent-blue hover:bg-blue-600 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition-colors min-w-[100px] disabled:cursor-wait"
        >
          <span class="btn-label">Search</span>
          <span class="btn-spinner w-3 h-3 border-2 border-white/35 border-t-white rounded-full opacity-0 animate-[search-spin_0.8s_linear_infinite]" aria-hidden="true"></span>
        </button>
        <span id="search-status" class="text-text-secondary text-sm min-w-[80px]" role="status" aria-live="polite"></span>
      </div>
    </form>
  </div>

  <div id="stats" class="mb-2">
    <p class="text-text-secondary text-sm">{total.toLocaleString()} results found</p>
  </div>
  <section id="wordles" class="transition-opacity duration-200">
    {hits.length === 0 ? (
      <div class="text-center py-12 text-text-secondary">
        <p>No results found.</p>
      </div>
    ) : (
      <div class="results-grid grid gap-3 grid-cols-1 sm:grid-cols-2 xl:grid-cols-3">
        {hits.map((val) => {
          const dateStr = val.dateTimestamp ? formatDate(val.dateTimestamp) : '';
          const link = val.url || '#';
          return (
            <article class="result-card border border-bg-tertiary rounded-lg p-4 transition-colors hover:bg-bg-secondary group">
              <div class="card-header flex justify-between items-baseline mb-2">
                <a href={link} target="_blank" class="text-text-primary text-sm font-medium hover:text-accent-blue transition-colors no-underline">{val.scorerName}</a>
                {val.score != null && <span class="card-score text-xl font-bold text-accent-blue">{val.score}</span>}
              </div>
              <div class="card-tags flex gap-1.5 flex-wrap mt-2">
                {val.wordleNumber ? <span class="tag bg-bg-tertiary rounded px-2 py-0.5 text-xs text-text-secondary group-hover:bg-bg-primary">Wordle #{val.wordleNumber}</span> : null}
                <span class="tag bg-bg-tertiary rounded px-2 py-0.5 text-xs text-text-secondary group-hover:bg-bg-primary">{val.solvedRow ? `Row ${val.solvedRow}` : 'Not solved'}</span>
                {!val.autoScore && <span class="tag-mention bg-accent-blue rounded px-2 py-0.5 text-xs text-white font-bold">@</span>}
                {dateStr && <span class="tag bg-bg-tertiary rounded px-2 py-0.5 text-xs text-text-secondary group-hover:bg-bg-primary">{dateStr}</span>}
              </div>
            </article>
          );
        })}
      </div>
    )}
  </section>
  <div id="pagination">
    {totalPages > 1 && (
      <div class="flex items-center gap-3 mt-5 flex-wrap">
        <span class="text-text-secondary text-sm">Page 1 of {totalPages}</span>
        <a href="#" class="page-link inline-block px-3 py-1.5 bg-bg-tertiary text-text-primary rounded-md text-sm hover:bg-accent-blue transition-colors no-underline" data-page="1">Next &raquo;</a>
      </div>
    )}
  </div>
</div>

<script>
  const searchbox = document.getElementById('searchbox')!;
  const form = document.getElementById('search-form') as HTMLFormElement;
  const wordlesContainer = document.getElementById('wordles')!;
  const paginationContainer = document.getElementById('pagination')!;
  const statsContainer = document.getElementById('stats')!;
  const statusEl = document.getElementById('search-status')!;
  const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  let currentPage = 0;
  let currentParams: Record<string, string> = {};
  let activeRequestId = 0;
  let lastResultsHeight = 0;
  let holdResultsHeight = false;

  bindPaginationLinks();

  function setLoadingState(isLoading: boolean) {
    form.classList.toggle('is-loading', isLoading);
    submitButton.disabled = isLoading;
    statusEl.textContent = isLoading ? 'Searching...' : '';

    if (isLoading) {
      holdResultsHeight = false;
      lastResultsHeight = wordlesContainer.offsetHeight;
      if (lastResultsHeight > 0) {
        wordlesContainer.style.minHeight = lastResultsHeight + 'px';
      }
      wordlesContainer.style.opacity = '0.5';
      wordlesContainer.setAttribute('aria-busy', 'true');
      statsContainer.style.opacity = '0.5';
      paginationContainer.style.opacity = '0.5';
    } else {
      wordlesContainer.style.opacity = '';
      statsContainer.style.opacity = '';
      paginationContainer.style.opacity = '';
      wordlesContainer.removeAttribute('aria-busy');
      if (holdResultsHeight && lastResultsHeight > 0) {
        wordlesContainer.style.minHeight = lastResultsHeight + 'px';
      } else {
        requestAnimationFrame(() => {
          wordlesContainer.style.minHeight = '';
        });
      }
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    currentPage = 0;
    const formData = new FormData(form);
    currentParams = {};
    for (const [key, val] of formData.entries()) {
      if (val) currentParams[key] = val as string;
    }
    fetchResults();
  });

  function fetchResults() {
    const requestId = ++activeRequestId;
    setLoadingState(true);
    const turnstileInput = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
    const token = turnstileInput?.value || '';
    const params = new URLSearchParams({ ...currentParams, page: String(currentPage), pageSize: '20', token });
    fetch('/api/search?' + params.toString())
      .then((r) => {
        if (r.status === 429) throw new Error('Too many searches — please wait a moment and try again.');
        if (!r.ok) throw new Error('Search request failed with status ' + r.status);
        return r.json();
      })
      .then((data) => {
        if (requestId !== activeRequestId) return;
        renderResults(data);
      })
      .catch((err) => {
        if (requestId !== activeRequestId) return;
        holdResultsHeight = false;
        wordlesContainer.textContent = '';
        const p = document.createElement('p');
        p.className = 'text-text-secondary text-sm py-4';
        p.textContent = err instanceof Error ? err.message : 'Error loading results.';
        wordlesContainer.appendChild(p);
        console.error(err);
      })
      .finally(() => {
        if (requestId !== activeRequestId) return;
        setLoadingState(false);
        if (typeof (window as any).turnstile !== 'undefined') (window as any).turnstile.reset();
      });
  }

  function renderResults(data: any) {
    if (statsContainer) {
      statsContainer.textContent = '';
      const p = document.createElement('p');
      p.className = 'text-text-secondary text-sm';
      p.textContent = data.total.toLocaleString() + ' results found';
      statsContainer.appendChild(p);
    }

    if (data.hits.length === 0) {
      holdResultsHeight = lastResultsHeight > 0;
      wordlesContainer.textContent = '';
      const emptyDiv = document.createElement('div');
      emptyDiv.className = 'text-center py-12 text-text-secondary';
      const p = document.createElement('p');
      p.textContent = 'No results found.';
      emptyDiv.appendChild(p);
      wordlesContainer.appendChild(emptyDiv);
      paginationContainer.textContent = '';
      return;
    }

    holdResultsHeight = false;
    wordlesContainer.textContent = '';

    const grid = document.createElement('div');
    grid.className = 'results-grid grid gap-3 grid-cols-1 sm:grid-cols-2 xl:grid-cols-3';

    for (const val of data.hits) {
      const dateStr = val.date_timestamp ? new Date(val.date_timestamp * 1000).toLocaleDateString('en-US') : '';
      const link = val.url || '#';

      const article = document.createElement('article');
      article.className = 'result-card border border-bg-tertiary rounded-lg p-4 transition-colors hover:bg-bg-secondary group';

      const header = document.createElement('div');
      header.className = 'card-header flex justify-between items-baseline mb-2';
      const a = document.createElement('a');
      a.href = link;
      a.target = '_blank';
      a.className = 'text-text-primary text-sm font-medium hover:text-accent-blue transition-colors';
      a.textContent = val.scorerName;
      header.appendChild(a);
      if (val.score != null) {
        const scoreSpan = document.createElement('span');
        scoreSpan.className = 'card-score text-xl font-bold text-accent-blue';
        scoreSpan.textContent = String(val.score);
        header.appendChild(scoreSpan);
      }
      article.appendChild(header);

      const tags = document.createElement('div');
      tags.className = 'card-tags flex gap-1.5 flex-wrap mt-2';
      if (val.wordleNumber) {
        const tag = document.createElement('span');
        tag.className = 'tag bg-bg-tertiary rounded px-2 py-0.5 text-xs text-text-secondary';
        tag.textContent = 'Wordle #' + val.wordleNumber;
        tags.appendChild(tag);
      }
      const rowTag = document.createElement('span');
      rowTag.className = 'tag bg-bg-tertiary rounded px-2 py-0.5 text-xs text-text-secondary';
      rowTag.textContent = val.solvedRow ? 'Row ' + val.solvedRow : 'Not solved';
      tags.appendChild(rowTag);
      if (!val.autoScore) {
        const mentionTag = document.createElement('span');
        mentionTag.className = 'tag-mention bg-accent-blue rounded px-2 py-0.5 text-xs text-white font-bold';
        mentionTag.textContent = '@';
        tags.appendChild(mentionTag);
      }
      if (dateStr) {
        const dateTag = document.createElement('span');
        dateTag.className = 'tag bg-bg-tertiary rounded px-2 py-0.5 text-xs text-text-secondary';
        dateTag.textContent = dateStr;
        tags.appendChild(dateTag);
      }
      article.appendChild(tags);

      grid.appendChild(article);
    }

    wordlesContainer.appendChild(grid);

    // Pagination
    paginationContainer.textContent = '';
    if (data.totalPages > 1) {
      const nav = document.createElement('div');
      nav.className = 'flex items-center gap-3 mt-5 flex-wrap';

      if (currentPage > 0) {
        const prev = document.createElement('a');
        prev.href = '#';
        prev.className = 'page-link inline-block px-3 py-1.5 bg-bg-tertiary text-text-primary rounded-md text-sm hover:bg-accent-blue transition-colors';
        prev.innerHTML = '&laquo; Prev';
        prev.addEventListener('click', (e) => {
          e.preventDefault();
          currentPage--;
          fetchResults();
          searchbox.scrollIntoView({ behavior: 'smooth' });
        });
        nav.appendChild(prev);
      }

      const info = document.createElement('span');
      info.className = 'text-text-secondary text-sm';
      info.textContent = 'Page ' + (currentPage + 1) + ' of ' + data.totalPages;
      nav.appendChild(info);

      if (currentPage < data.totalPages - 1) {
        const next = document.createElement('a');
        next.href = '#';
        next.className = 'page-link inline-block px-3 py-1.5 bg-bg-tertiary text-text-primary rounded-md text-sm hover:bg-accent-blue transition-colors';
        next.innerHTML = 'Next &raquo;';
        next.addEventListener('click', (e) => {
          e.preventDefault();
          currentPage++;
          fetchResults();
          searchbox.scrollIntoView({ behavior: 'smooth' });
        });
        nav.appendChild(next);
      }

      paginationContainer.appendChild(nav);
    }
  }

  function bindPaginationLinks() {
    paginationContainer.querySelectorAll('.page-link').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        currentPage = parseInt((link as HTMLElement).dataset.page || '0', 10);
        fetchResults();
        searchbox.scrollIntoView({ behavior: 'smooth' });
      });
    });
  }
</script>

<style>
  form.is-loading .btn-spinner {
    opacity: 1;
  }
</style>
